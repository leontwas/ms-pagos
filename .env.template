PORT=3004
NODE_ENV=development

# Base de datos (PostgreSQL)
# Local (docker compose):  postgresql://canchas_user:canchas_pass@localhost:5432/canchas_db
# Supabase (prod):         usar el connection string del Session Pooler (IPv4, puerto 5432)
DATABASE_URL=postgresql://canchas_user:canchas_pass@localhost:5432/canchas_db
# false en local; true en Supabase/prod (requiere SSL)
DATABASE_SSL=false

# URL de api-turnos (confirma la reserva al cubrir la seña)
# Local: http://localhost:3003   |   Prod: URL pública de api-turnos en Render
TURNOS_URL=http://localhost:3003

MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
